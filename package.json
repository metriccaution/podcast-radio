{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/ui/index.ts",
    "build": "bun build ./src/ui/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "format": "prettier --write .",
    "pretest": "bun run format",
    "test": "tsc && bun test"
  },
  "dependencies": {
    "dayjs": "^1.11.21",
    "fast-xml-parser": "^5.8.0",
    "prettier": "^3.8.3",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^6.0.3"
  }
}
