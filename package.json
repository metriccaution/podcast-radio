{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/ui/index.ts",
    "build": "BUN_PUBLIC_BUILD_TIME=$(date -u '+%Y-%m-%dT%H:%M:%SZ') bun build ./src/ui/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*' && cp src/ui/icon-192.png src/ui/icon-512.png dist/",
    "generate-icons": "bun src/generate-icons.ts",
    "format": "prettier --write .",
    "pretest": "bun run format",
    "test": "tsc && bun test"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "fast-xml-parser": "^5.8.0",
    "prettier": "^3.8.3",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^6.0.3"
  }
}
